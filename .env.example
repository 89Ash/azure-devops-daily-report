# Azure DevOps connection
ADO_ORG_URL=https://dev.azure.com/your-org
ADO_PAT=your-personal-access-token-here
ADO_PROJECT=your-project-name

# Optional: limit to a specific area path (e.g. "YourProject\\TeamName")
# ADO_AREA_PATH=YourProject\\YourTeam

# Optional: comma-separated closed/done states to exclude from active counts
# ADO_CLOSED_STATES=Closed,Done,Removed,Resolved

# Child work item types excluded from the tracker view (default: Task)
# ADO_EXCLUDED_TYPES=Task

# High-priority levels for dedicated defect queries (1=Critical, 2=High)
# ADO_DEFECT_TYPES=Bug,Defect
# ADO_HIGH_PRIORITY_LEVELS=1,2

# Default shared query to show on load (query name, path, or ID; overrides AZURE_QUERY1/2)
# ADO_DEFAULT_QUERY=My Priority Items

# Fallback default queries (tried in order when ADO_DEFAULT_QUERY is not set)
# AzureQuery1 — first shared query name to select on dashboard load
AZURE_QUERY1=My Priority Query
# AzureQuery2 — second fallback if AzureQuery1 is not found
AZURE_QUERY2=My Secondary Query

# Report output
REPORT_OUTPUT_DIR=reports
